# Never commit plaintext secrets or private keys.
# This is the envseal tool's OWN repo — it does not carry a real secret store. If you dogfood
# envseal here (`envseal init`), the generated store/recipients are ignored so they aren't
# committed. (In a normal project that USES envseal, you DO commit recipients + secrets.enc.)
/recipients
/secrets/

# Decrypted / plaintext env files
*.dec.env
*.decrypted
.env
.env.*
!.env.example

# age private keys / identities (envseal keeps yours in ~/.config/envseal/identity.txt,
# but guard against a stray copy landing in the repo).
identity.txt
keys.txt
*.age
*.age.key
*.agekey

# envseal edit temp file (should be shredded, but never commit it)
.envseal-edit.tmp

# Rust build output. With the workspace root Cargo.toml, output lands in ./target;
# bin/target is kept ignored too in case the crate is built in isolation.
/target/
bin/target/

# OS / editor cruft
.DS_Store
*.swp
