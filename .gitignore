# Never commit plaintext secrets or private keys.
# This is the envstow tool's OWN repo — it does not carry a real secret store. If you dogfood
# envstow here (`envstow init`), the generated .envstow/ dir is ignored so it isn't committed.
# (In a normal project that USES envstow, you DO commit the .envstow/ dir.)
/.envstow/

# Decrypted / plaintext env files
*.dec.env
*.decrypted
.env
.env.*
!.env.example

# age private keys / identities (envstow keeps yours in ~/.config/envstow/identity.txt,
# but guard against a stray copy landing in the repo).
identity.txt
keys.txt
*.age
*.age.key
*.agekey

# envstow edit temp file (should be shredded, but never commit it)
.envstow-edit.tmp

# Rust build output. With the workspace root Cargo.toml, output lands in ./target;
# the crate's own target is kept ignored too in case it's built in isolation.
/target/
crates/envstow/target/

# OS / editor cruft
.DS_Store
*.swp
