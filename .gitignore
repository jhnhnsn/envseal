# Never commit plaintext secrets or private keys.
# The ONLY secrets file that belongs in git is secrets/*.enc.env (encrypted).

# Decrypted / plaintext env files
*.dec.env
*.decrypted
.env
.env.*
!.env.example

# age / private keys
keys.txt
*.age
*.age.key
*.agekey

# direnv local state
.direnv/

# Rust build output (the envseal launcher crate lives in bin/)
bin/target/

# OS / editor cruft
.DS_Store
*.swp
