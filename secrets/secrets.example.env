# Example secrets file (plaintext, safe to commit — NO real values).
#
# Copy the shape of this file into the encrypted store:
#   1. cp secrets/secrets.example.env /tmp/seed.env   # fill in REAL values
#   2. sops --encrypt /tmp/seed.env > secrets/secrets.enc.env
#   3. rm /tmp/seed.env
# Or just run `sops secrets/secrets.enc.env` and add keys in the editor.
#
# Variable names should end in _KEY / _TOKEN / _SECRET / _PASSWORD or start with API_
# so the redact-guard hook recognizes them as secrets.

FLY_API_TOKEN=fly-token-goes-here
CLOUDFLARE_API_TOKEN=cf-token-goes-here
AWS_SECRET_ACCESS_KEY=aws-secret-goes-here
OPENAI_API_KEY=sk-example
DATABASE_PASSWORD=example-db-password
