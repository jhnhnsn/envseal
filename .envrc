# direnv unlock gate — decrypts secrets into the environment ONLY on explicit opt-in.
#
# direnv itself will not run this file until you approve it with `direnv allow`,
# so a malicious edit in a PR cannot auto-execute. On top of that, this gate
# requires you to set a sentinel each session so merely `cd`-ing in never
# silently decrypts your secrets.
#
#   Opt in:   export SECRETS_UNLOCK=1 && direnv reload
#   Opt out:  unset SECRETS_UNLOCK && direnv reload
#
# Once unlocked, start your AI coding session IN THIS SHELL. Child processes
# (npm, make, fly, gradle, curl ...) inherit the vars; the AI references them by
# NAME only and never needs to read the plaintext.

if [ "${SECRETS_UNLOCK:-}" = "1" ]; then
  if command -v sops >/dev/null 2>&1; then
    if [ -f secrets/secrets.enc.env ]; then
      # Load decrypted values into this shell's env, in-memory only.
      # direnv unloads them automatically when you leave the directory.
      eval "$(sops -d --output-type dotenv secrets/secrets.enc.env | sed 's/^/export /')"
      echo "🔓 envseal: secrets loaded into environment for this session"
    else
      echo "⚠️  envseal: secrets/secrets.enc.env not found — nothing to load"
    fi
  else
    echo "⚠️  envseal: sops not installed — secrets NOT loaded"
  fi
else
  echo "🔒 envseal: secrets locked. Run: export SECRETS_UNLOCK=1 && direnv reload"
fi
